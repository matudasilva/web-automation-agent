BASE_URL=https://www.facebook.com
ALLOWED_DOMAIN=facebook.com

# Browser settings
BROWSER=firefox
HEADLESS=false
BROWSER_PROFILE_DIR=./runtime/profiles/example-browser-profile
SCREENSHOT_DIR=./screenshots
UI_ACTION_DELAY_MS=700
UI_ITERATION_DELAY_MS=1500

# Manual checkpoints
WAIT_FOR_MANUAL_READY=true
WAIT_FOR_MANUAL_PUBLISH_CONFIRMATION=true

# Single-target mode
MARKETPLACE_LISTING_TITLE=Example marketplace listing title
MARKETPLACE_GROUP_NAME=Example group name

# Multi-target mode
MARKETPLACE_GROUP_TARGETS_FILE=./runtime/group_targets.txt
